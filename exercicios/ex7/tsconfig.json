{
    "compilerOptions": {
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "lib": ["DOM","ESNext"],
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",

        "rootDir": "src",
        "outDir": "build",
    },

    "include": ["src"],
    "exclude": ["node_modules"]
}